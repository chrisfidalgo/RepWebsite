---
interface Props {
  title: string;
  description: string;
  extendedDescription?: string;
  icon?: string; // CSS background-position for the icon sprite (e.g. "0% 0%")
}

const { title, description, extendedDescription, icon } = Astro.props;
---

<article class="issue-card card">
  {icon ? (
    <div class="issue-icon-row">
      <span class="issue-accent" aria-hidden="true"></span>
      <img
        src={icon}
        alt=""
        class="issue-icon-img"
        aria-hidden="true"
        width="147"
        height="147"
      />
    </div>
  ) : (
    <span class="accent-bar" aria-hidden="true"></span>
  )}
  <h3>{title}</h3>
  <p>{description}</p>
  {extendedDescription && <p class="extended">{extendedDescription}</p>}
</article>

<style>
  .issue-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    background: var(--color-cream);
  }

  .issue-card h3 {
    font-size: 1.1rem;
    color: var(--color-navy);
  }

  .issue-card p {
    font-size: 0.95rem;
    color: var(--color-slate);
    line-height: 1.65;
    max-width: none;
  }

  .issue-card .extended {
    color: var(--color-charcoal);
    font-size: 0.9rem;
    margin-top: 0.5rem;
    padding-top: 0.75rem;
    border-top: 1px solid #e8eef5;
  }

  .issue-icon-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.85rem;
    margin-bottom: 0.25rem;
  }

  .issue-accent {
    display: block;
    width: 4px;
    height: 147px;
    background-color: var(--color-red);
    border-radius: 2px;
    flex-shrink: 0;
  }

  .issue-icon-img {
    width: 147px;
    height: 147px !important;
    object-fit: contain;
    flex-shrink: 0;
  }
</style>
