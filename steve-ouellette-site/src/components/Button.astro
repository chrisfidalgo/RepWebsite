---
interface Props {
  href: string;
  label: string;
  variant?: 'primary' | 'secondary' | 'secondary-light';
  external?: boolean;
}

const { href, label, variant = 'primary', external = false } = Astro.props;

const classes = {
  primary: 'btn btn-primary',
  secondary: 'btn btn-secondary',
  'secondary-light': 'btn btn-secondary--light',
}[variant];
---

<a
  href={href}
  class={classes}
  {...external ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
>
  {label}
  {external && <span aria-hidden="true">↗</span>}
</a>
