---
const footerLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/priorities', label: 'Priorities' },
  { href: '/delivering-for-the-district', label: 'Results for the District' },
  { href: '/community-updates', label: 'Community Updates' },
  { href: '/contact', label: 'Contact' },
];

const communities = ['Acushnet', 'Fall River', 'Freetown', 'New Bedford', 'Westport'];
---

<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <div class="footer-logo-wrap">
          <img
            src="/images/wave-logo.png"
            alt="Steve Ouellette, State Representative, 8th Bristol District"
            class="footer-logo"
          />
        </div>
        <span class="footer-tagline">Believe in Steve.</span>
        <div class="footer-contact">
          <a href="tel:7745261599">(774) 526-1599</a>
          <a href="mailto:Steve.Ouellette@mahouse.gov">Steve.Ouellette@mahouse.gov</a>
        </div>
        <div class="footer-communities" aria-label="Communities served">
          <span class="communities-label">Serving:</span>
          {communities.map((c) => (
            <span class="community-pill">{c}</span>
          ))}
        </div>
      </div>

      <nav class="footer-nav" aria-label="Footer navigation">
        <ul role="list">
          {footerLinks.map(({ href, label }) => (
            <li><a href={href}>{label}</a></li>
          ))}
          <li><a href="/contact#privacy" aria-label="Privacy and data use policy">Privacy / Data Use</a></li>
        </ul>
        <a
          href="https://secure.actblue.com/donate/steven-ouellette-1"
          class="btn footer-donate"
          target="_blank"
          rel="noopener noreferrer"
        >Donate</a>
      </nav>
    </div>

    <div class="footer-compliance">
      <p class="disclaimer-primary">
        Paid for by the Committee to Elect Ouellette.
      </p>
      <p class="disclaimer-secondary">
        This is a campaign website. For official State House business, contact Representative
        Ouellette's official legislative office at (617) 722-2060 or
        Steve.Ouellette@mahouse.gov.
      </p>
      <p class="disclaimer-privacy">
        Privacy note: Information submitted through this site may be used by the campaign
        to respond to inquiries and provide updates.
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-charcoal);
    color: var(--color-white);
    padding-block: 2rem 1.5rem;
    margin-top: auto;
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem;
    margin-bottom: 1.5rem;
    align-items: start;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer-logo-wrap {
    background: white;
    border-radius: 6px;
    padding: 4px 10px;
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
  }

  .footer-logo {
    height: 72px;
    width: auto;
    display: block;
  }

  .footer-tagline {
    font-size: 1rem;
    font-style: italic;
    color: rgba(242, 243, 244, 0.75);
  }

  .footer-contact {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .footer-contact a,
  .footer-contact span {
    font-size: 0.85rem;
    color: rgba(242, 243, 244, 0.65);
    text-decoration: none;
  }

  .footer-contact a:hover {
    color: var(--color-white);
    text-decoration: underline;
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 1rem;
  }

  .footer-nav ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-align: right;
  }

  .footer-donate {
    background-color: var(--color-red);
    color: var(--color-white) !important;
    border: 2px solid var(--color-red);
    font-size: 0.9rem;
    padding: 0.55rem 1.5rem;
    text-decoration: none !important;
  }

  .footer-donate:hover {
    background-color: #c42640;
    border-color: #c42640;
  }

  .footer-nav a {
    color: rgba(242, 243, 244, 0.8);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.15s;
  }

  .footer-nav a:hover {
    color: var(--color-white);
  }

  .footer-communities {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.5rem;
  }

  .communities-label {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgba(242, 243, 244, 0.55);
    margin-right: 0.25rem;
  }

  .community-pill {
    display: inline-block;
    padding: 0.2rem 0.65rem;
    background-color: rgba(255, 255, 255, 0.1);
    border-radius: 999px;
    font-size: 0.8rem;
    color: rgba(242, 243, 244, 0.85);
    border: 1px solid rgba(255, 255, 255, 0.15);
  }

  .footer-compliance {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    padding-top: 1.25rem;
  }

  .disclaimer-primary {
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--color-white);
  }

  .disclaimer-secondary,
  .disclaimer-privacy {
    font-size: 0.8rem;
    color: rgba(242, 243, 244, 0.55);
    max-width: 80ch;
  }

  @media (max-width: 640px) {
    .footer-top {
      grid-template-columns: 1fr;
    }

    .footer-nav ul {
      text-align: left;
      flex-direction: row;
      flex-wrap: wrap;
      gap: 0.5rem 1.25rem;
    }
  }
</style>
