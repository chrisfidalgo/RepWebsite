---
---

<section class="hero" aria-label="Campaign hero">
  <div class="container hero-inner">
    <div class="hero-content">
      <div class="hero-tagline-pill">8th Bristol District · Massachusetts</div>
      <h1 class="hero-headline">Believe in Steve.</h1>
      <p class="hero-subheadline">
        Local experience. Real results. Steve Ouellette is working for the
        communities of the 8th Bristol District.
      </p>
      <p class="hero-body">
        Steve has spent decades serving South Coast communities — in public
        safety, municipal government, the trades, and now at the State House.
        His approach is simple: listen first, work with people, and deliver
        practical results for the district.
      </p>

      <div class="hero-actions">
        <a href="#signup" class="btn btn-primary">Sign up for updates</a>
        <a href="/contact" class="btn btn-secondary--light">Contact Steve</a>
      </div>

      <div class="hero-tertiary">
        <a href="/constituent-services#citation">Request a citation or resolution →</a>
      </div>
    </div>

    <div class="hero-image-area">
      <img
        src="/images/steve-hero.jpg"
        alt="Steve Ouellette waving from a Ford tractor at a community event in the 8th Bristol District"
        class="hero-photo"
      />
    </div>
  </div>

  <!-- Community pills strip -->
  <div class="hero-communities" aria-label="Communities served">
    <div class="container">
      <span class="communities-prefix">Serving communities across:</span>
      {['Acushnet', 'Fall River', 'Freetown', 'New Bedford', 'Westport'].map(c => (
        <span class="community-chip">{c}</span>
      ))}
    </div>
  </div>
</section>

<style>
  .hero {
    background: linear-gradient(145deg, var(--color-navy) 0%, var(--color-blue) 100%);
    color: var(--color-white);
    padding-top: 4.5rem;
    padding-bottom: 0;
    overflow: hidden;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
    padding-bottom: 4rem;
  }

  .hero-tagline-pill {
    display: inline-block;
    padding: 0.3rem 0.9rem;
    background-color: var(--color-red);
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-white);
    margin-bottom: 1.25rem;
  }

  .hero-headline {
    font-size: clamp(2.5rem, 6vw, 4rem);
    color: var(--color-white);
    margin-bottom: 1rem;
    line-height: 1.1;
  }

  .hero-subheadline {
    font-size: 1.2rem;
    color: rgba(242, 243, 244, 0.9);
    font-weight: 600;
    margin-bottom: 1rem;
    max-width: none;
  }

  .hero-body {
    font-size: 1rem;
    color: rgba(242, 243, 244, 0.78);
    margin-bottom: 2rem;
    max-width: none;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }

  .hero-tertiary a {
    color: rgba(242, 243, 244, 0.75);
    font-size: 0.9rem;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .hero-tertiary a:hover {
    color: var(--color-white);
  }

  .hero-photo {
    width: 100%;
    max-height: 520px;
    object-fit: cover;
    object-position: center top;
    border-radius: var(--radius-lg);
    display: block;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
  }

  .hero-communities {
    background-color: rgba(0, 0, 0, 0.25);
    padding-block: 0.85rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .hero-communities .container {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
  }

  .communities-prefix {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgba(242, 243, 244, 0.55);
    margin-right: 0.25rem;
  }

  .community-chip {
    display: inline-block;
    padding: 0.2rem 0.7rem;
    background-color: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 999px;
    font-size: 0.8rem;
    color: rgba(242, 243, 244, 0.9);
  }

  @media (max-width: 820px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }

    .hero-image-area {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding-top: 3rem;
    }
  }
</style>
