---
interface Props {
  image: string;
  imagePosition?: string;
  imageSize?: string;
  gradientSolidEnd?: string;
  gradientFadeEnd?: string;
  headline: string;
  subheadline: string;
}

const {
  image,
  imagePosition = 'right 45%',
  imageSize = '60% auto',
  gradientSolidEnd = '41%',
  gradientFadeEnd = '60%',
  headline,
  subheadline,
} = Astro.props;
---

<section
  class="hero"
  aria-label="Page hero"
  style={`background-image: url('${image}'); background-position: ${imagePosition}; background-size: ${imageSize};`}
>
  <div
    class="hero-overlay"
    aria-hidden="true"
    style={`background: linear-gradient(to right, rgba(12, 30, 68, 1.0) 0%, rgba(21, 52, 118, 1.0) ${gradientSolidEnd}, rgba(28, 70, 159, 0.2) ${gradientFadeEnd}, rgba(30, 75, 170, 0.0) 100%);`}
  ></div>

  <div class="container hero-inner">
    <div class="hero-content">
      <h1 class="hero-headline">{headline}</h1>
      <p class="hero-subheadline">{subheadline}</p>
      <slot />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    background-color: #0C1E44;
    background-repeat: no-repeat;
    color: var(--color-white);
    padding-top: 5rem;
    padding-bottom: 0;
    -webkit-mask-image: url('/images/hero-mask.png');
    mask-image: url('/images/hero-mask.png');
    mask-size: 100% 100%;
    mask-repeat: no-repeat;
  }

  /* Solid left panel fading into the photo at the seam — gradient set via inline style */
  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    padding-bottom: 4.5rem;
  }

  .hero-content {
    max-width: 500px;
  }

  .hero-headline {
    font-size: clamp(2.5rem, 6vw, 4rem);
    color: var(--color-white);
    margin-bottom: 1rem;
    line-height: 1.1;
  }

  .hero-subheadline {
    font-size: 1.15rem;
    color: rgba(242, 243, 244, 0.9);
    font-weight: 600;
    margin-bottom: 0;
    max-width: none;
    line-height: 1.55;
  }

  /* When slotted content follows, add spacing above it */
  .hero-subheadline:not(:last-child) {
    margin-bottom: 2rem;
  }

  @media (max-width: 480px) {
    .hero {
      padding-top: 3rem;
    }

    .hero-inner {
      padding-bottom: 3rem;
    }
  }
</style>
