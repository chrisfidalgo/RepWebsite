---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import SignupFormPlaceholder from '../components/SignupFormPlaceholder.astro';
import Hero from '../components/Hero.astro';
---

<BaseLayout
  title="Contact Steve Ouellette — 8th Bristol District Campaign"
  description="Get in touch with Steve Ouellette's campaign. Sign up for updates, request a citation, or ask about constituent services."
>
  <!-- Page hero -->
  <Hero
    image="/images/steve-down-point.png"
    imagePosition="55% 42%"
    imageSize="38% auto"
    gradient="linear-gradient(to right, rgba(12,30,68,1) 0%, rgba(21,52,118,1) 29%, rgba(28,70,159,0.2) 40%, rgba(29,72,164,0) 58%, rgba(30,74,167,1) 72%, rgba(30,75,170,1) 100%)"
    headline="Contact Steve"
    subheadline="We're here to help. Use the options below to connect with the campaign or request specific services."
  />

  <section class="section section--white">
    <div class="container">
      <div class="contact-layout">

        <!-- Section 1: Sign up -->
        <div class="contact-section card" id="signup">
          <span class="accent-bar"></span>
          <h2>Sign up for campaign updates</h2>
          <p>
            Stay informed about Steve's work in the district, office hours,
            events, and ways to get involved.
          </p>
          <SignupFormPlaceholder />
        </div>

        <!-- Section 2: Contact the campaign -->
        <div class="contact-section card" id="campaign-contact">
          <span class="accent-bar"></span>
          <h2>Contact the campaign</h2>
          <p>
            Have a question, comment, or want to connect with the campaign team?
            Use this form to send us a message.
          </p>

          <div class="form-placeholder-banner" role="note">
            ⚠ FORM PLACEHOLDER — Replace with a Google Form embed or approved contact form before launch.
          </div>

          <!-- Replace this with approved contact form -->
          <div class="google-form-placeholder" aria-label="Contact form placeholder">
            <!--
              INSTRUCTIONS: Replace this div with a Google Form iframe embed.

              Example:
              <iframe
                src="https://docs.google.com/forms/d/e/YOUR_FORM_ID/viewform?embedded=true"
                width="100%"
                height="700"
                frameborder="0"
                marginheight="0"
                marginwidth="0"
                title="Campaign contact form"
                loading="lazy"
              >
                Loading form...
              </iframe>
            -->
            <p>[Google Form embed goes here — replace this block with the iframe from Google Forms]</p>
          </div>
        </div>

        <!-- Section 3: Invite Steve to an Event -->
        <div class="contact-section card" id="invite">
          <span class="accent-bar"></span>
          <h2>Invite Steve to an Event</h2>
          <p>
            Steve welcomes invitations to community events, organizational
            meetings, school visits, and local gatherings across the 8th
            Bristol District.
          </p>
          <a href="#campaign-contact" class="btn btn-primary">Send an Invitation</a>
        </div>

      </div>
    </div>
  </section>

  <!-- Privacy anchor -->
  <div id="privacy" class="section section--white">
    <div class="container">
      <div class="privacy-block info-box">
        <h3>Privacy and Data Use</h3>
        <p>
          Information submitted through this site may be used by the campaign to
          respond to inquiries and provide updates. Full privacy language is pending
          review and will be added before launch.
        </p>
        <p class="placeholder-note">
          [PLACEHOLDER — Replace with reviewed privacy policy language before launch.]
        </p>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  :global(.hero) {
    min-height: 380px !important;
    align-items: flex-start !important;
    padding-top: 4rem !important;
  }

  :global(.hero-headline),
  :global(.hero-subheadline) {
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.55);
  }

  .contact-layout {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .contact-section {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .contact-section h2 {
    font-size: 1.4rem;
  }

  .contact-section p {
    font-size: 0.95rem;
    color: var(--color-charcoal);
    max-width: none;
    line-height: 1.7;
  }

  .google-form-placeholder {
    background-color: #f0f2f5;
    border: 2px dashed var(--color-muted-blue);
    border-radius: var(--radius);
    padding: 3rem 2rem;
    text-align: center;
    color: var(--color-slate);
    font-size: 0.9rem;
    font-style: italic;
  }

  .placeholder-note {
    font-size: 0.83rem !important;
    color: #e07b00 !important;
    font-style: italic;
    background-color: #fff9ee;
    border: 1px solid #ffd07a;
    border-radius: 4px;
    padding: 0.5rem 0.75rem;
  }

  .privacy-block h3 {
    font-size: 1.1rem;
    margin-bottom: 0.75rem;
    color: var(--color-navy);
  }

  .privacy-block p {
    font-size: 0.9rem;
    color: var(--color-charcoal);
    max-width: none;
    margin-bottom: 0.5rem;
  }
</style>
