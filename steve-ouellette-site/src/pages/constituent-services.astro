---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Hero from '../components/Hero.astro';
---

<BaseLayout
  title="Constituent Services — Steve Ouellette, 8th Bristol District"
  description="Steve Ouellette's office helps connect residents with resources, answer questions, and direct requests to the right place."
>
  <!-- Page hero -->
  <Hero
    image="/images/senior-visit.jpg"
    imagePosition="right 35%"
    imageSize="55% auto"
    gradientSolidEnd="49%"
    gradientFadeEnd="65%"
    headline="Constituent Services"
    subheadline="Steve's team can help connect residents with resources, answer questions, and direct requests to the right place."
  />

  <section class="section section--white" style="padding-bottom: 2.5rem;">
    <div class="container">

      <div class="services-grid">

        <!-- Service 1: State Agency Assistance -->
        <div class="service-card card" id="state-issue">
          <span class="accent-bar"></span>
          <h2>State Agency Assistance</h2>
          <p>
            Running into a problem with a state agency, benefit program, or
            government process? Steve's team can help you understand your
            options, connect you with the right office, or advocate on your
            behalf.
          </p>
          <p class="service-examples">
            <strong>Examples:</strong> MassHealth, unemployment benefits, RMV issues,
            state benefit navigation, housing programs, agency communication problems.
          </p>
          <a href="/contact" class="btn btn-primary service-btn">Request Help</a>
        </div>

        <!-- Service 2: Veterans Resources -->
        <div class="service-card card">
          <span class="accent-bar"></span>
          <h2>Veterans Resources</h2>
          <p>
            Steve's office can connect veterans and their families with state and
            federal benefits, services, and support programs available through
            the Commonwealth and local organizations.
          </p>
          <p class="service-examples">
            <strong>Examples:</strong> Veterans benefits navigation, VA assistance,
            local veterans services referrals, state veterans programs.
          </p>
          <a href="/contact" class="btn btn-primary service-btn">Contact the Office</a>
        </div>

        <!-- Service 3: Senior Services -->
        <div class="service-card card">
          <span class="accent-bar"></span>
          <h2>Senior Services</h2>
          <p>
            Our office can connect seniors with Council on Aging programs,
            housing resources, transportation assistance, and other services
            available across the district.
          </p>
          <p class="service-examples">
            <strong>Examples:</strong> Council on Aging referrals, housing resources,
            senior transportation, SHINE health insurance counseling, benefit assistance.
          </p>
          <a href="/contact" class="btn btn-primary service-btn">Contact the Office</a>
        </div>

        <!-- Service 4: Transportation Assistance -->
        <div class="service-card card">
          <span class="accent-bar"></span>
          <h2>Transportation Assistance</h2>
          <p>
            Our team can help residents navigate transportation concerns, RMV
            issues, and accessibility questions related to public transit and
            state transportation services.
          </p>
          <p class="service-examples">
            <strong>Examples:</strong> RMV problems, transit service concerns,
            accessibility questions, transportation program referrals.
          </p>
          <a href="/contact" class="btn btn-primary service-btn">Contact the Office</a>
        </div>

        <!-- Service 5: Grants & Programs -->
        <div class="service-card card">
          <span class="accent-bar"></span>
          <h2>Grants &amp; Programs</h2>
          <p>
            Steve's office can provide guidance on state grant programs and
            funding opportunities available to organizations, nonprofits, and
            municipalities across the 8th Bristol District.
          </p>
          <p class="service-examples">
            <strong>Examples:</strong> Municipal grant programs, nonprofit funding
            opportunities, state infrastructure funding, community program grants.
          </p>
          <a href="/contact" class="btn btn-primary service-btn">Contact the Office</a>
        </div>

        <!-- Service 6: Citation or resolution -->
        <div class="service-card card" id="citation">
          <span class="accent-bar"></span>
          <h2>Request a Citation or Resolution</h2>
          <p>
            Citations and resolutions are formal acknowledgments from the
            Massachusetts Legislature recognizing milestones, achievements,
            organizations, and community events.
          </p>
          <p class="service-examples">
            <strong>Examples:</strong> Retirements, anniversaries, graduations,
            community recognition, organizational milestones, public service.
          </p>
          <a href="/contact" class="btn btn-primary service-btn">Request Citation or Resolution</a>
        </div>

      </div>
    </div>
  </section>

  <!-- Official office contact -->
  <section class="section section--white" style="padding-top: 2.5rem;">
    <div class="container">
      <div class="official-contact-layout">
        <div class="official-disclaimer info-box">
          <h3>Official State House Contact</h3>
          <p>
            For matters requiring official legislative action or correspondence,
            please contact Representative Ouellette's official State House office
            directly. Campaign and official legislative staff are separate.
          </p>

          <div class="contact-details">
            <div class="contact-detail-group">
              <span class="contact-label">Boston State House</span>
              <span class="contact-value">24 Beacon Street, Room 33, Boston, MA 02133</span>
            </div>
            <div class="contact-detail-group">
              <span class="contact-label">Boston Office Phone</span>
              <a href="tel:6177222060" class="contact-value">(617) 722-2060</a>
            </div>
            <div class="contact-detail-group">
              <span class="contact-label">District Office Phone</span>
              <a href="tel:5086770905" class="contact-value">(508) 677-0905</a>
            </div>
            <div class="contact-detail-group">
              <span class="contact-label">Official Email</span>
              <a href="mailto:Steve.Ouellette@mahouse.gov" class="contact-value">Steve.Ouellette@mahouse.gov</a>
            </div>
            <div class="contact-detail-group">
              <span class="contact-label">Campaign Contact</span>
              <a href="/contact" class="contact-value">Use the contact form →</a>
            </div>
          </div>
        </div>

        <!-- Invite Steve card -->
        <div class="invite-card card">
          <span class="accent-bar"></span>
          <h3>Invite Steve to an Event</h3>
          <p>
            Steve welcomes invitations to community events, organizational
            meetings, school visits, and local gatherings across the 8th
            Bristol District.
          </p>
          <a href="/contact" class="btn btn-primary service-btn">Send an Invitation</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .service-card.card,
  .invite-card.card {
    background: #fdf8f0;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .service-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .service-card h2 {
    font-size: 1.2rem;
  }

  .service-card p {
    font-size: 0.93rem;
    color: var(--color-charcoal);
    max-width: none;
    line-height: 1.65;
  }

  .service-examples {
    background-color: #f5f7fb;
    border-radius: var(--radius);
    padding: 0.75rem 1rem;
    font-size: 0.85rem !important;
    color: var(--color-slate) !important;
  }

  .service-btn {
    align-self: flex-start;
    margin-top: 0.5rem;
  }

  /* Official contact section */
  .official-contact-layout {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 2rem;
    align-items: start;
  }

  .official-disclaimer h3 {
    font-size: 1.1rem;
    margin-bottom: 0.75rem;
    color: var(--color-navy);
  }

  .official-disclaimer p {
    font-size: 0.93rem;
    color: var(--color-charcoal);
    max-width: none;
    margin-bottom: 1rem;
  }

  .contact-details {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    padding: 1.25rem;
    background-color: #f5f7fb;
    border-radius: var(--radius);
  }

  .contact-detail-group {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .contact-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-muted-blue);
  }

  .contact-value {
    font-size: 0.95rem;
    color: var(--color-charcoal);
    text-decoration: none;
  }

  .contact-value:hover {
    text-decoration: underline;
    color: var(--color-blue);
  }

  .invite-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .invite-card h3 {
    font-size: 1.2rem;
  }

  .invite-card p {
    font-size: 0.93rem;
    color: var(--color-charcoal);
    max-width: none;
    line-height: 1.65;
  }

  @media (max-width: 860px) {
    .official-contact-layout {
      grid-template-columns: 1fr;
    }
  }
</style>
